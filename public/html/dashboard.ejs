<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GTPSID · modern & bright</title>
    <link rel="icon" href="https://s3.eu-west-1.amazonaws.com/cdn.growtopiagame.com/website/resources/assets/images/growtopia.ico" />
    <!-- Font modern: Inter + fallback sistem sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <style>
        /* reset & base — clean, light, smooth */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            min-height: 100vh;
            background: linear-gradient(145deg, #f0f5fe 0%, #e6edf9 100%);
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* main card — soft, bright, smooth shadow */
        .main-container {
            width: 100%;
            max-width: 700px;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(4px);
            background: #ffffff;
            border-radius: 36px;
            box-shadow: 0 25px 50px -10px rgba(0, 35, 75, 0.18), 0 0 0 1px rgba(156, 188, 226, 0.3) inset;
            overflow: hidden;
            transition: all 0.25s ease;
        }

        /* header section — fresh gradient, clean typography */
        .visual-section {
            background: linear-gradient(125deg, #d4e2fc 0%, #bbd4fb 70%, #a9c7fa 100%);
            padding: 2.5rem 2rem 2rem;
            text-align: center;
            color: #0b2d4b;
            border-bottom: 1px solid rgba(255, 255, 255, 0.6);
        }

        .visual-section h1 {
            font-weight: 500;
            font-size: 1rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            color: #2563eb;
            background: rgba(255, 255, 255, 0.5);
            display: inline-block;
            padding: 0.2rem 1rem;
            border-radius: 30px;
            backdrop-filter: blur(2px);
            margin-bottom: 0.75rem;
        }

        .visual-section h2 {
            font-size: 3rem;
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 0.75rem;
            background: linear-gradient(135deg, #0f2b50, #1d4ed8);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.02em;
        }

        .visual-section p {
            max-width: 460px;
            margin: 1rem auto 0;
            font-weight: 400;
            font-size: 0.95rem;
            color: #1e3a5f;
            background: rgba(255, 255, 255, 0.45);
            padding: 0.8rem 1.2rem;
            border-radius: 60px;
            backdrop-filter: blur(3px);
            line-height: 1.5;
        }

        .icon-container {
            width: 64px;
            height: 64px;
            background: white;
            border-radius: 50%;
            margin: 0 auto 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px -5px rgba(37, 99, 235, 0.2);
        }
        .icon-container::before {
            content: "🌱";
            font-size: 2.2rem;
            filter: drop-shadow(0 2px 4px rgba(0,80,120,0.2));
        }

        /* form wrapper — sliding area dengan transisi halus */
        .form-wrapper {
            position: relative;
            background: #ffffff;
            padding: 0 2rem 2rem;
            min-height: 480px;
            transition: height 0.45s cubic-bezier(0.23, 1, 0.32, 1);
            overflow: hidden;
            border-radius: 0 0 36px 36px;
        }

        /* kedua form sebagai absolute, digeser dengan transform + opacity */
        .form-container {
            width: 100%;
            padding: 1.8rem 0 1rem;
            transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.3s ease, visibility 0.3s;
            position: absolute;
            top: 0;
            left: 0;
            will-change: transform, opacity;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .form-main-content {
            width: 100%;
            max-width: 400px;
        }

        /* default: login terlihat, register di kanan (tersembunyi) */
        #registerFormContent {
            transform: translateX(100%);
            opacity: 0;
            visibility: hidden;
        }
        #loginFormContent {
            transform: translateX(0);
            opacity: 1;
            visibility: visible;
        }

        /* saat wrapper punya class slide-to-register: login ke kiri, register masuk */
        .form-wrapper.slide-to-register #loginFormContent {
            transform: translateX(-100%);
            opacity: 0;
            visibility: hidden;
        }
        .form-wrapper.slide-to-register #registerFormContent {
            transform: translateX(0);
            opacity: 1;
            visibility: visible;
        }

        /* slide to login (default, tapi untuk toggle balik) */
        .form-wrapper.slide-to-login #loginFormContent {
            transform: translateX(0);
            opacity: 1;
            visibility: visible;
        }
        .form-wrapper.slide-to-login #registerFormContent {
            transform: translateX(100%);
            opacity: 0;
            visibility: hidden;
        }

        /* title halus */
        .form-title {
            margin-bottom: 1.8rem;
            text-align: center;
        }
        .form-title h1 {
            font-size: 0.9rem;
            font-weight: 500;
            letter-spacing: 0.03em;
            color: #4b6a9b;
            text-transform: uppercase;
        }
        .form-title h2 {
            font-size: 2.1rem;
            font-weight: 700;
            color: #0b2b50;
            letter-spacing: -0.02em;
        }

        /* input grup modern */
        .input-group {
            margin-bottom: 1.25rem;
            position: relative;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 0.9rem 1.2rem;
            font-size: 1rem;
            background: #f8fafd;
            border: 1.5px solid #dee9f2;
            border-radius: 20px;
            outline: none;
            transition: all 0.2s;
            color: #0f2b44;
            font-weight: 500;
            box-shadow: 0 2px 6px rgba(0, 27, 55, 0.03);
        }

        input:focus {
            border-color: #3b82f6;
            background: #ffffff;
            box-shadow: 0 8px 18px -8px rgba(59, 130, 246, 0.25);
        }

        /* tombol smooth */
        button {
            font-family: 'Inter', sans-serif;
            border: none;
            cursor: pointer;
            transition: 0.15s ease;
        }

        .btn-primary {
            width: 100%;
            padding: 1rem;
            background: #2266cc;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            border-radius: 40px;
            box-shadow: 0 8px 16px -6px #1e4faa70;
            margin-top: 0.75rem;
            letter-spacing: 0.01em;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .btn-primary:hover {
            background: #1a55b0;
            transform: scale(1.01);
            box-shadow: 0 12px 20px -8px #1e4faa;
        }
        .btn-primary:active {
            transform: scale(0.98);
            background: #154a99;
        }

        .btn-secondary {
            background: transparent;
            border: 1.5px solid #b7cef0;
            padding: 0.85rem 1.2rem;
            border-radius: 40px;
            font-weight: 600;
            color: #1d4a8b;
            width: auto;
            min-width: 200px;
            margin-top: 0.25rem;
            transition: background 0.2s, border 0.2s;
        }
        .btn-secondary:hover {
            background: #e5f0ff;
            border-color: #3b82f6;
        }

        .toggle-password {
            font-size: 0.85rem;
            font-weight: 500;
            color: #3b68b0;
            cursor: pointer;
            margin: 0.25rem 0 0.8rem 0.5rem;
            display: inline-block;
            background: #ecf3fd;
            padding: 0.3rem 1rem;
            border-radius: 30px;
            transition: background 0.2s;
        }
        .toggle-password:hover {
            background: #d5e5ff;
        }

        /* switch section & footer */
        .switch-section {
            margin-top: 2.2rem;
            padding-top: 1.2rem;
            border-top: 2px dashed #cbdff5;
            width: 100%;
            max-width: 400px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }
        .switch-section p {
            font-weight: 500;
            color: #31639c;
        }

        .footer {
            font-size: 0.75rem;
            color: #799ac0;
            margin-top: 0.5rem;
        }

        /* message box lembut */
        .message-box {
            padding: 0.9rem 1.2rem;
            border-radius: 60px;
            margin: 1rem 0 0.5rem;
            font-weight: 500;
            font-size: 0.9rem;
            background: #f0f9ff;
            border: 1px solid #b9d5fd;
            color: #0256b2;
            display: none;
            text-align: center;
        }
        .message-error {
            background: #fff2f0;
            border-color: #ffbbb1;
            color: #b53b2a;
        }

        /* autocomplete list minimal */
        .autocomplete-list {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 24px;
            box-shadow: 0 16px 30px -10px rgba(0,50,100,0.2);
            list-style: none;
            padding: 0.6rem 0;
            margin-top: 4px;
            z-index: 30;
            border: 1px solid #d7e5fd;
        }
        .autocomplete-list li {
            padding: 0.65rem 1.5rem;
            cursor: pointer;
            font-weight: 500;
            color: #10345e;
        }
        .autocomplete-list li:hover {
            background: #e8f0fe;
        }

        /* tidak ada efek pixel, semua mulus */
        .pixel-font {
            /* fallback dihapus, tidak digunakan */
        }
    </style>
</head>
<body>
<div class="main-container">
    <div class="visual-section">
        <div class="icon-container"></div>
        <h1>Welcome to</h1>
        <h2>GTPSID</h2>
        <p>Connect with thousands of players worldwide. Join the adventure in the world of Growtopia and explore endless possibilities!</p>
    </div>

    <div class="form-wrapper" id="formWrapper">
        <!-- LOGIN FORM -->
        <div class="form-container" id="loginFormContent">
            <div class="form-main-content">
                <div class="form-title">
                    <h1>welcome back</h1>
                    <h2>log in</h2>
                </div>

                <form method="POST" action="/player/growid/login/validate" autocomplete="off" id="loginForm">
                    <div class="input-group">
                        <input type="text" name="_token" id="loginServerInput" placeholder="Server name *" required />
                    </div>
                    <div class="input-group">
                        <input type="text" name="growId" id="loginGrowId" placeholder="Your GrowID *" required />
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" id="loginPassword" placeholder="Password *" required />
                    </div>
                    <div class="toggle-password" id="toggleLoginPassword">👁️ show password</div>
                    <button type="submit" name="action" value="Login" class="btn-primary">Log in</button>
                </form>
            </div>

            <div class="switch-section">
                <p>Don't have an account?</p>
                <button type="button" class="btn-secondary" onclick="switchForm('register')">Create account</button>
                <div class="footer">© 2025 GTPSID · bright edition</div>
            </div>
        </div>

        <!-- REGISTER FORM -->
        <div class="form-container" id="registerFormContent">
            <div class="form-main-content">
                <div class="form-title">
                    <h1>new here?</h1>
                    <h2>sign up</h2>
                </div>

                <form method="POST" action="/player/growid/login/validate" autocomplete="off" id="registerForm">
                    <div class="input-group">
                        <input type="text" name="_token" id="registerServerInput" placeholder="Server name *" required />
                    </div>
                    <div class="input-group">
                        <input type="text" name="growId" id="registerGrowId" placeholder="Choose GrowID *" required />
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" id="registerPassword" placeholder="Password *" required />
                    </div>
                    <div class="input-group">
                        <input type="password" name="confirmPassword" id="confirmPassword" placeholder="Confirm password *" required />
                    </div>
                    <div class="toggle-password" id="toggleRegisterPassword">👁️ show password</div>
                    <button type="submit" name="action" value="Register" class="btn-primary">Register</button>
                </form>
            </div>
            <div class="switch-section">
                <p>Already have an account?</p>
                <button type="button" class="btn-secondary" onclick="switchForm('login')">Back to login</button>
                <div class="footer">© 2025 GTPSID · bright edition</div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        // daftar server
        const servers = ["STYLOPS", "CHINAPS", "COASTPS", "SLOWLYPS", "NEXPS", "TESPS", "IDLEPS"];

        const formWrapper = document.getElementById('formWrapper');
        const loginContent = document.getElementById('loginFormContent');
        const registerContent = document.getElementById('registerFormContent');

        // tinggi wrapper dinamis — halus
        function setWrapperHeight(element) {
            // gunakan scrollHeight agar akurat meskipun ada margin/padding
            setTimeout(() => {
                const h = element.scrollHeight;
                if (h > 50) formWrapper.style.height = h + 'px';
            }, 10);
        }

        // fungsi switch dengan transisi
        window.switchForm = function(target) {
            const nextActive = target === 'register' ? registerContent : loginContent;
            setWrapperHeight(nextActive);

            formWrapper.classList.remove('slide-to-login', 'slide-to-register');
            if (target === 'register') {
                formWrapper.classList.add('slide-to-register');
            } else {
                formWrapper.classList.add('slide-to-login');
            }
        };

        // inisialisasi tinggi dan local storage
        document.addEventListener('DOMContentLoaded', function() {
            // recall growid & server
            const savedGrowId = localStorage.getItem('growId');
            const savedServer = localStorage.getItem('lastServer');
            if (savedGrowId) {
                document.getElementById('loginGrowId').value = savedGrowId;
                document.getElementById('registerGrowId').value = savedGrowId;
            }
            if (savedServer) {
                document.getElementById('loginServerInput').value = savedServer;
                document.getElementById('registerServerInput').value = savedServer;
            }

            // setup autocomplete kedua input
            setupAutocomplete('loginServerInput');
            setupAutocomplete('registerServerInput');

            // tinggi awal
            setWrapperHeight(loginContent);

            // event listeners toggle password
            document.getElementById('toggleLoginPassword').addEventListener('click', function() {
                togglePass('loginPassword', this);
            });
            document.getElementById('toggleRegisterPassword').addEventListener('click', function() {
                togglePass('registerPassword', this);
                togglePass('confirmPassword', this);  // untuk konfirmasi juga di-toggle (sama)
            });
        });

        // toggle password function
        function togglePass(fieldId, toggleEl) {
            const field = document.getElementById(fieldId);
            if (!field) return;
            const isPassword = field.type === 'password';
            field.type = isPassword ? 'text' : 'password';
            toggleEl.textContent = isPassword ? '👁️ hide password' : '👁️ show password';
        }

        // autocomplete
        function setupAutocomplete(inputId) {
            const input = document.getElementById(inputId);
            let listBox = null;

            input.addEventListener('input', function(e) {
                const val = this.value.toUpperCase().trim();
                if (listBox) { listBox.remove(); listBox = null; }
                if (val === '') return;

                const matches = servers.filter(s => s.startsWith(val));
                if (matches.length === 0) return;

                listBox = document.createElement('ul');
                listBox.className = 'autocomplete-list';
                const parentGroup = this.closest('.input-group');
                if (!parentGroup) return;
                parentGroup.style.position = 'relative';

                matches.forEach(m => {
                    const li = document.createElement('li');
                    li.textContent = m;
                    li.onclick = () => {
                        input.value = m;
                        if (listBox) { listBox.remove(); listBox = null; }
                    };
                    listBox.appendChild(li);
                });
                parentGroup.appendChild(listBox);
            });

            document.addEventListener('click', (e) => {
                if (listBox && !input.contains(e.target) && !listBox.contains(e.target)) {
                    listBox.remove();
                    listBox = null;
                }
            });
        }

        // validasi & submit login
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            const server = document.getElementById('loginServerInput').value.trim();
            const growId = document.getElementById('loginGrowId').value.trim();
            const pwd = document.getElementById('loginPassword').value;

            if (!server || !growId || !pwd) {
                e.preventDefault();
                showMessage('Please fill all fields', 'error', 'loginFormContent');
                return;
            }
            localStorage.setItem('growId', growId);
            localStorage.setItem('lastServer', server);
            console.log('login ok', { server, growId });
            // e.preventDefault(); // untuk demo, biarkan terkirim (jika perlu)
        });

        document.getElementById('registerForm').addEventListener('submit', function(e) {
            const server = document.getElementById('registerServerInput').value.trim();
            const growId = document.getElementById('registerGrowId').value.trim();
            const pwd = document.getElementById('registerPassword').value;
            const confirm = document.getElementById('confirmPassword').value;

            if (!server || !growId || !pwd || !confirm) {
                e.preventDefault();
                showMessage('All fields required', 'error', 'registerFormContent');
                return;
            }
            if (pwd !== confirm) {
                e.preventDefault();
                showMessage('Passwords do not match', 'error', 'registerFormContent');
                return;
            }
            if (pwd.length < 4) {
                e.preventDefault();
                showMessage('Password min 4 characters', 'error', 'registerFormContent');
                return;
            }
            localStorage.setItem('growId', growId);
            localStorage.setItem('lastServer', server);
            console.log('register ok', { server, growId });
        });

        function showMessage(msg, type, parentId) {
            const parent = document.getElementById(parentId);
            if (!parent) return;
            const form = parent.querySelector('form');
            if (!form) return;
            let box = parent.querySelector('.message-box');
            if (!box) {
                box = document.createElement('div');
                box.className = 'message-box';
                form.parentNode.insertBefore(box, form);
            }
            box.textContent = msg;
            box.classList.toggle('message-error', type === 'error');
            box.style.display = 'block';

            // sesuaikan tinggi setelah message muncul
            setWrapperHeight(parent);

            setTimeout(() => {
                box.style.display = 'none';
                setWrapperHeight(parent);
            }, 3500);
        }

        // memastikan tinggi pas di resize (opsional)
        window.addEventListener('resize', () => {
            const active = formWrapper.classList.contains('slide-to-register') ? registerContent : loginContent;
            setWrapperHeight(active);
        });
    })();
</script>
</body>
</html>
