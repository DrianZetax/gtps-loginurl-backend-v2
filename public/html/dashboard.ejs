<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GTPSID · fresh green</title>
    <link rel="icon" href="https://euphonious-squirrel-375e9c.netlify.app/grotopia.jpg" />
    <!-- clean modern font + pixel accent -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            background: radial-gradient(circle at 10% 30%, #1b4d3d, #0f2f24);
            font-family: 'Inter', system-ui, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        /* main card – fresh green gradients */
        .gt-card {
            max-width: 1000px;
            width: 100%;
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            background: #e6f0ea;
            border-radius: 48px 48px 40px 40px;
            box-shadow: 0 30px 40px -20px rgba(0, 40, 20, 0.6), 0 0 0 2px #98c0aa inset, 0 0 0 5px #f5fffa inset;
            overflow: hidden;
            transition: all 0.3s;
        }

        /* LEFT PANEL — hijau dengan LOGO GROWTOPIA.JPG (ASLI) */
        .brand-panel {
            flex: 1 1 280px;
            background: linear-gradient(145deg, #1e6b4c, #134532);
            padding: 3rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: #f1fff0;
            position: relative;
            border-right: 4px solid #b3e6c9;
            box-shadow: inset 0 0 30px #b7eeca40;
        }

        .brand-panel::after {
            content: "";
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(45deg, #fff1ba0a 0px, #fff1ba0a 12px, transparent 12px, transparent 24px);
            pointer-events: none;
        }

        /* ============================================= */
        /* INI ADALAH TEMPAT LOGO GROWTOPIA.JPG (ASLI)  */
        /* ============================================= */
        .growtopia-logo-img {
            width: 140px;        /* ukuran logo, sesuaikan dengan gambar Anda */
            height: 140px;
            margin-bottom: 25px;
            background: transparent;  /* tidak ada background buatan */
            border: none;             /* tidak ada bingkai tambahan */
            box-shadow: none;         /* tanpa bayangan, biar logo asli yang tampil */
            overflow: hidden;
            transition: transform 0.2s ease;
        }
        .growtopia-logo-img:hover {
            transform: scale(1.03);   /* efek kecil saat hover */
        }

        /* GAMBAR LOGO GROWTOPIA.JPG AKAN MENGISI KOTAK INI */
        .growtopia-logo-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;     /* supaya logo tidak terpotong dan proporsional */
            display: block;
        }

        /* judul GTPSID */
        .brand-panel h1 {
            font-family: 'Press Start 2P', cursive;
            font-size: 20px;
            line-height: 1.5;
            color: #fbffd0;
            text-shadow: 0 3px 0 #0f4d2e, 0 5px 10px #1f3b2b;
            margin-bottom: 5px;
        }

        /* dekorasi opsional, bisa dihapus */
        .leaf-decoration {
            margin-top: 30px;
            display: flex;
            gap: 16px;
            font-size: 24px;
            color: #c0f0cf;
            letter-spacing: 6px;
        }

        /* RIGHT PANEL – slider area (fresh white / light green) */
        .form-panel {
            flex: 2 1 400px;
            background: #effbf3;
            backdrop-filter: blur(2px);
            padding: 2.8rem 2.5rem;
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 0 2px #d1f0dd;
        }

        /* form wrapper for sliding effect */
        .form-slider {
            position: relative;
            min-height: 480px;
            transition: height 0.45s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .form-card {
            position: absolute;
            width: 100%;
            left: 0;
            top: 0;
            transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.3s, visibility 0.3s;
            background: transparent;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 0.8rem 0 2rem 0;
        }

        /* center content wrapper */
        .form-inner {
            width: 100%;
            max-width: 360px;
            display: flex;
            flex-direction: column;
            align-items: stretch;
        }

        /* login visible, register hidden to the right */
        #loginCard {
            transform: translateX(0);
            opacity: 1;
            visibility: visible;
        }
        #registerCard {
            transform: translateX(110%);
            opacity: 0;
            visibility: hidden;
        }

        /* sliding states */
        .form-slider.show-register #loginCard {
            transform: translateX(-110%);
            opacity: 0;
            visibility: hidden;
        }
        .form-slider.show-register #registerCard {
            transform: translateX(0);
            opacity: 1;
            visibility: visible;
        }

        /* headings */
        .form-inner h3 {
            font-size: 14px;
            letter-spacing: 1.5px;
            color: #1f704c;
            margin-bottom: 5px;
            text-transform: uppercase;
        }
        .form-inner h2 {
            font-family: 'Press Start 2P', cursive;
            font-size: 22px;
            color: #1e4f36;
            margin-bottom: 28px;
            text-shadow: 3px 3px 0 #b5e3c4;
            word-break: break-word;
        }

        /* green input group */
        .input-group {
            margin-bottom: 16px;
            position: relative;
        }
        .input-group input {
            width: 100%;
            background: #ffffff;
            border: 2.5px solid #9ac7b0;
            border-radius: 30px;
            padding: 14px 20px;
            font-size: 16px;
            font-weight: 500;
            color: #114d31;
            outline: none;
            transition: all 0.2s;
            box-shadow: 0 5px 0 #c0e0cd;
        }
        .input-group input:focus {
            border-color: #1d8e5a;
            box-shadow: 0 5px 0 #469e70, 0 0 0 4px #dcfce8;
        }
        .input-group input::placeholder {
            color: #719b82;
            font-weight: 400;
            opacity: 0.8;
        }

        /* show/hide password toggle */
        .toggle-pwd {
            font-size: 14px;
            font-weight: 600;
            color: #267a50;
            margin: 8px 0 14px 10px;
            display: inline-block;
            cursor: pointer;
            background: #dcf5e6;
            padding: 5px 15px;
            border-radius: 50px;
            border: 1.5px solid #7ebe9a;
            transition: 0.15s;
        }
        .toggle-pwd:hover {
            background: #bef5d8;
        }

        /* primary button – fresh green */
        .btn-primary {
            width: 100%;
            background: #269961;
            border: none;
            border-radius: 40px;
            padding: 16px 20px;
            font-family: 'Press Start 2P', cursive;
            font-size: 16px;
            color: #f2ffe6;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 7px 0 #115e38, 0 10px 15px rgba(0, 30, 10, 0.3);
            cursor: pointer;
            transition: all 0.1s ease;
            border: 2px solid #bef5c1;
            margin-top: 8px;
        }
        .btn-primary:active {
            transform: translateY(5px);
            box-shadow: 0 2px 0 #115e38, 0 8px 15px rgba(0, 30, 10, 0.2);
        }

        .btn-secondary {
            background: transparent;
            border: 3px solid #278f5a;
            border-radius: 40px;
            padding: 12px 24px;
            font-family: 'Press Start 2P', cursive;
            font-size: 13px;
            color: #1d7548;
            box-shadow: 0 4px 0 #a5d6b8;
            cursor: pointer;
            transition: 0.1s;
            width: 100%;
            margin-top: 8px;
            background: #e6ffe6;
        }
        .btn-secondary:active {
            transform: translateY(4px);
            box-shadow: none;
        }

        /* switch section & footer */
        .switch-section {
            margin-top: 35px;
            text-align: center;
            border-top: 2px dashed #9fcbb2;
            padding-top: 25px;
        }
        .switch-section p {
            color: #0f412c;
            font-weight: 600;
            font-size: 15px;
            margin-bottom: 8px;
        }
        .footer-note {
            margin-top: 30px;
            font-size: 12px;
            color: #47755b;
            font-weight: 500;
        }

        .message-box {
            background: #f1fff0;
            border-radius: 50px;
            padding: 12px 18px;
            margin-bottom: 20px;
            text-align: center;
            font-weight: 600;
            border-left: 6px solid #1f8f5a;
            color: #185f3a;
            display: none;
            border: 2px solid #b1e6c0;
        }
        .message-error {
            border-left-color: #c73b3b;
            background: #ffe9e9;
            color: #a12424;
        }

        /* autocomplete suggestion */
        .autocomplete-list {
            position: absolute;
            background: white;
            border: 2px solid #7ebc99;
            border-radius: 24px;
            list-style: none;
            width: 100%;
            z-index: 99;
            top: calc(100% + 4px);
            left: 0;
            overflow: hidden;
            box-shadow: 0 15px 25px -12px #1e4d33;
        }
        .autocomplete-list li {
            padding: 12px 22px;
            cursor: pointer;
            font-weight: 600;
            color: #154d30;
            background: #effff0;
            border-bottom: 1px solid #b3e3c2;
            transition: 0.1s;
        }
        .autocomplete-list li:hover {
            background: #b7f2cf;
        }

        /* responsive */
        @media (max-width: 700px) {
            .gt-card { flex-direction: column; border-radius: 36px; }
            .brand-panel { border-right: none; border-bottom: 4px solid #a5e0bd; }
        }
    </style>
</head>
<body>
    <div class="gt-card">
        <!-- panel kiri dengan LOGO GROWTOPIA.JPG (ASLI) DI ATAS GTPSID -->
        <div class="brand-panel">
            <div class="growtopia-logo-img">
                <!-- ================================================================= -->
                <!-- GANTI 'growtopia.jpg' DENGAN NAMA FILE GAMBAR LOGO ASLI ANDA      -->
                <!-- PASTIKAN FILE GAMBAR BERADA DI FOLDER YANG SAMA DENGAN FILE HTML -->
                <!-- ================================================================= -->
                <img src="growtopia.jpg" alt="Growtopia Logo" onerror="this.style.display='none'; this.parentElement.style.background='#d1f7d9'; this.parentElement.innerHTML='<span style=\'display: flex; align-items: center; justify-content: center; height: 100%; font-family: Press Start 2P; font-size: 24px; color: #1e4f36;\'>GT</span>';">
                <!-- Jika gambar tidak ditemukan, akan menampilkan teks 'GT' sebagai fallback -->
            </div>
            <h1>GTPSID</h1>
            <!-- tidak ada teks tambahan -->
            <div class="leaf-decoration">
                <span>⬩</span> <span>⬩</span> <span>⬩</span>
            </div>
        </div>

        <!-- form panel geser kanan -->
        <div class="form-panel">
            <div class="form-slider" id="formSlider">
                <!-- LOGIN CARD -->
                <div class="form-card" id="loginCard">
                    <div class="form-inner">
                        <h3>welcome back</h3>
                        <h2>LOG IN</h2>
                        <form method="POST" action="/player/growid/login/validate" id="loginForm">
                            <div class="input-group">
                                <input type="text" name="_token" id="loginServerInput" placeholder="server name *" required autocomplete="off">
                            </div>
                            <div class="input-group">
                                <input type="text" name="growId" id="loginGrowId" placeholder="your GrowID *" required>
                            </div>
                            <div class="input-group">
                                <input type="password" name="password" id="loginPassword" placeholder="password *" required>
                            </div>
                            <span class="toggle-pwd" id="toggleLoginPassword">show password</span>
                            <button type="submit" class="btn-primary">login</button>
                        </form>
                        <!-- switch & footer inside inner -->
                        <div class="switch-section">
                            <p>new here?</p>
                            <button type="button" class="btn-secondary" onclick="switchForm('register')">create account</button>
                            <div class="footer-note">© 2025 GTPSID</div>
                        </div>
                    </div>
                </div>

                <!-- REGISTER CARD -->
                <div class="form-card" id="registerCard">
                    <div class="form-inner">
                        <h3>join the jungle</h3>
                        <h2>REGISTER</h2>
                        <form method="POST" action="/player/growid/login/validate" id="registerForm">
                            <div class="input-group">
                                <input type="text" name="_token" id="registerServerInput" placeholder="server name *" required autocomplete="off">
                            </div>
                            <div class="input-group">
                                <input type="text" name="growId" id="registerGrowId" placeholder="choose GrowID *" required>
                            </div>
                            <div class="input-group">
                                <input type="password" name="password" id="registerPassword" placeholder="password *" required>
                            </div>
                            <div class="input-group">
                                <input type="password" name="confirmPassword" id="confirmPassword" placeholder="confirm password *" required>
                            </div>
                            <span class="toggle-pwd" id="toggleRegisterPassword">show password</span>
                            <button type="submit" class="btn-primary">register</button>
                        </form>
                        <div class="switch-section">
                            <p>already have account?</p>
                            <button type="button" class="btn-secondary" onclick="switchForm('login')">back to login</button>
                            <div class="footer-note">© 2025 GTPSID</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            // Server list (green style)
            const servers = ["STYLOPS", "CHINAPS", "COASTPS", "SLOWLYPS", "NEXPS", "TESPS", "IDLEPS"];

            const slider = document.getElementById('formSlider');
            const loginCard = document.getElementById('loginCard');
            const registerCard = document.getElementById('registerCard');

            // ——— Helper: adjust slider height to active card ———
            function setSliderHeight(activeCard) {
                setTimeout(() => {
                    if (activeCard) {
                        const h = activeCard.scrollHeight;
                        slider.style.height = h + 'px';
                    }
                }, 20);
            }

            // initial height (login)
            setSliderHeight(loginCard);

            // switch function (global)
            window.switchForm = function(target) {
                if (target === 'register') {
                    slider.classList.add('show-register');
                    slider.classList.remove('show-login');
                    setSliderHeight(registerCard);
                } else {
                    slider.classList.remove('show-register');
                    setSliderHeight(loginCard);
                }
            };

            // toggle password
            document.getElementById('toggleLoginPassword').addEventListener('click', function() {
                toggleField('loginPassword', this);
            });
            document.getElementById('toggleRegisterPassword').addEventListener('click', function() {
                toggleField('registerPassword', this);
                toggleField('confirmPassword', this);
            });

            function toggleField(fieldId, btn) {
                const pwd = document.getElementById(fieldId);
                if (!pwd) return;
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    btn.innerHTML = 'hide password';
                } else {
                    pwd.type = 'password';
                    btn.innerHTML = 'show password';
                }
            }

            // autocomplete server
            function setupAutoComplete(inputId) {
                const input = document.getElementById(inputId);
                if (!input) return;
                let listBox = null;

                input.addEventListener('input', function() {
                    if (listBox) { listBox.remove(); listBox = null; }
                    const val = this.value.toUpperCase();
                    if (!val) return;

                    const matches = servers.filter(s => s.startsWith(val));
                    if (matches.length === 0) return;

                    listBox = document.createElement('ul');
                    listBox.className = 'autocomplete-list';
                    matches.forEach(m => {
                        const li = document.createElement('li');
                        li.textContent = m;
                        li.onclick = () => {
                            input.value = m;
                            listBox?.remove();
                            listBox = null;
                        };
                        listBox.appendChild(li);
                    });

                    const parent = input.closest('.input-group');
                    if (parent) {
                        parent.style.position = 'relative';
                        parent.appendChild(listBox);
                    }
                });

                document.addEventListener('click', (e) => {
                    if (listBox && !input.contains(e.target) && !listBox.contains(e.target)) {
                        listBox.remove();
                        listBox = null;
                    }
                });
            }

            // localStorage prefill & events
            document.addEventListener('DOMContentLoaded', function() {
                const savedGrowId = localStorage.getItem('growId');
                const savedServer = localStorage.getItem('lastServer');

                if (savedGrowId) {
                    document.getElementById('loginGrowId').value = savedGrowId;
                    document.getElementById('registerGrowId').value = savedGrowId;
                }
                if (savedServer) {
                    document.getElementById('loginServerInput').value = savedServer;
                    document.getElementById('registerServerInput').value = savedServer;
                }

                setupAutoComplete('loginServerInput');
                setupAutoComplete('registerServerInput');

                window.showMessage = function(msg, type, parentId) {
                    const parent = document.getElementById(parentId);
                    if (!parent) return;
                    const form = parent.querySelector('form');
                    if (!form) return;
                    let box = parent.querySelector('.message-box');
                    if (!box) {
                        box = document.createElement('div');
                        box.className = 'message-box';
                        form.parentNode.insertBefore(box, form);
                    }
                    box.textContent = msg;
                    box.className = `message-box ${type === 'error' ? 'message-error' : ''}`;
                    box.style.display = 'block';
                    setSliderHeight(parent.closest('.form-card'));

                    setTimeout(() => {
                        box.style.display = 'none';
                        setSliderHeight(parent.closest('.form-card'));
                    }, 4000);
                };
            });

            // login submit
            document.getElementById('loginForm')?.addEventListener('submit', function(e) {
                const server = document.getElementById('loginServerInput').value.trim();
                const growId = document.getElementById('loginGrowId').value.trim();
                const pwd = document.getElementById('loginPassword').value;

                if (!server || !growId || !pwd) {
                    e.preventDefault();
                    showMessage('all fields required!', 'error', 'loginCard');
                    return;
                }
                localStorage.setItem('growId', growId);
                localStorage.setItem('lastServer', server);
                console.log('login attempt', { server, growId });
            });

            // register submit
            document.getElementById('registerForm')?.addEventListener('submit', function(e) {
                const server = document.getElementById('registerServerInput').value.trim();
                const growId = document.getElementById('registerGrowId').value.trim();
                const pwd = document.getElementById('registerPassword').value;
                const confirm = document.getElementById('confirmPassword').value;

                if (!server || !growId || !pwd || !confirm) {
                    e.preventDefault();
                    showMessage('fill everything!', 'error', 'registerCard');
                    return;
                }
                if (pwd !== confirm) {
                    e.preventDefault();
                    showMessage('passwords do not match', 'error', 'registerCard');
                    return;
                }
                if (pwd.length < 4) {
                    e.preventDefault();
                    showMessage('password min 4 characters', 'error', 'registerCard');
                    return;
                }
                localStorage.setItem('growId', growId);
                localStorage.setItem('lastServer', server);
                console.log('register', { server, growId });
            });

            window.addEventListener('resize', function() {
                const active = slider.classList.contains('show-register') ? registerCard : loginCard;
                setSliderHeight(active);
            });
        })();
    </script>
</body>
</html>
